rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // The agent's own account has no dealId claim on its token. A client's
    // token (minted only by the verifyClientAccess Cloud Function, after
    // it has confirmed their last name/zip server-side) always has one,
    // scoped to exactly the transaction they verified for. This is the
    // whole security model in two lines: agent = no claim = full access;
    // client = claim = access to that one deal, nothing else.
    function isAgent() {
      return request.auth != null && request.auth.token.get('dealId', null) == null;
    }
    function isVerifiedClientFor(txnId) {
      return request.auth != null && request.auth.token.get('dealId', null) == txnId;
    }

    match /deals/{txnId} {
      // Listing every transaction is an agent-only operation.
      allow list: if isAgent();

      // Reading one deal is allowed for the agent, or for a client who
      // has already passed verification for this specific transaction.
      // Nobody reads deal data without going through one of those two
      // paths — there is no "if true" left anywhere in this file.
      allow get: if isAgent() || isVerifiedClientFor(txnId);

      allow create, update, delete: if isAgent();

      match /messages/{messageId} {
        allow read: if isAgent() || isVerifiedClientFor(txnId);
        allow create: if (isAgent() || isVerifiedClientFor(txnId))
                       && request.resource.data.keys().hasOnly(['from', 'text', 'createdAt'])
                       && request.resource.data.from in ['agent', 'client'];
        allow update, delete: if false;
      }
    }

    // Watched by the Trigger Email extension. Agent-only — clients never
    // write here directly.
    match /mail/{mailId} {
      allow create: if isAgent();
      allow read, update, delete: if false;
    }
  }
}
