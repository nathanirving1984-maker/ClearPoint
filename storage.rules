rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /deals/{txnId}/{fileName} {
      // Same "unlisted ID" reasoning as firestore.rules: readable by
      // anyone who has the exact file path (which requires already
      // knowing the txnId), writable only by the signed-in agent.
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
