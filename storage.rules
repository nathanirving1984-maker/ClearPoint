rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /deals/{txnId}/{fileName} {
      // Read stays open: download URLs already embed an unguessable
      // token, and the only way to ever see one is via the deal document,
      // which is now itself gated by verified auth (see firestore.rules).
      // Write is agent-only — a verified client's token has a `dealId`
      // claim, a real agent's doesn't, so this excludes client tokens
      // even though both are "signed in".
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.get('dealId', null) == null;
    }
  }
}
